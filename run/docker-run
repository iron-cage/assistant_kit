#!/usr/bin/env bash
# Universal Docker test runner.
# Usage: docker-run <config.yml> [command]
#   command: .build | . | .test | .test.offline | .shell | .help  (default: .test)
set -euo pipefail

CONFIG="$1"
COMMAND="${2:-.test}"

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
WORKSPACE_ROOT="$( cd "$SCRIPT_DIR/.." && pwd )"

# ── Config reader (flat YAML — no external parser required) ───────────────────
# Strips "key: " prefix and surrounding double-quotes from value.

cfg() { grep -m1 "^$1:" "$CONFIG" | sed 's/^[^:]*:[[:space:]]*//' | tr -d '"'; }

IMAGE="$(cfg image)"                              # image tag for -t at build and image lookup at run
DOCKERFILE="$WORKSPACE_ROOT/runbox.dockerfile"    # runbox system build file (always at workspace root)
TEST_USER="$(cfg test_user)"                      # forwarded as --build-arg; non-root for chmod-000 tests
CMD_SCOPE="$(cfg cmd_scope)"                      # crate filter for nextest run and cargo chef cook
CMD_FILTER="$(cfg cmd_filter)"                    # forwarded as --build-arg; nextest filter baked into offline CMD
TEST_SCRIPT="$(cfg test_script)"                  # path (relative to /workspace) exec'd by cmd_test
BIN_PLUGIN="$(cfg bin_plugin)"                    # optional binary plugin: name:container_path
BIN_PLUGIN_VOLUME="$(cfg bin_plugin_volume)"      # container mount point for bin_plugin working volume
PLUGIN_MOUNT="$(cfg plugin_mount)"                # data dir plugin: host_path:container_path:check_type

# ── Mount resolver ────────────────────────────────────────────────────────────
# Spec format: "host_path:container_path:check_type"  (3 fields from runbox.yml)
#   check_type: file | directory
# Caller passes required (true|false) and mode (ro|rw) as positional args.
# On success: prints "host:container:mode" ready for -v flag.
# On required+missing: prints error and exits.
# On optional+missing: prints nothing (caller checks with -n).

_resolve_mount()
{
  # spec format: "host_path:container_path:check_type"
  # Caller provides required (true|false) and mode (ro|rw).
  local spec="$1" required="$2" mode="${3:-ro}"
  local host container check rest
  host="${spec%%:*}";      rest="${spec#*:}"
  container="${rest%%:*}"; check="${rest#*:}"
  host="${host/#\~/$HOME}"

  local present=false
  [[ "$check" == "file"      ]] && [[ -f "$host" ]] && present=true
  [[ "$check" == "directory" ]] && [[ -d "$host" ]] && present=true

  if ! $present
  then
    if [[ "$required" == "true" ]]
    then
      echo "error: required mount not found at $host" >&2
      exit 1
    fi
    return 0
  fi

  echo "$host:$container:$mode"
}

# ── Container runtime ─────────────────────────────────────────────────────────

if command -v podman &>/dev/null
then
  CONTAINER_CMD=podman
elif command -v docker &>/dev/null
then
  CONTAINER_CMD=docker
else
  echo "error: neither podman nor docker found" >&2
  exit 1
fi

# ── Helpers ───────────────────────────────────────────────────────────────────

_build()
{
  echo "Building $IMAGE using $CONTAINER_CMD..."
  # shellcheck disable=SC2086
  "$CONTAINER_CMD" build \
    -f "$DOCKERFILE" \
    --build-arg "TEST_USER=$TEST_USER" \
    --build-arg "CMD_SCOPE=$CMD_SCOPE" \
    --build-arg "CMD_FILTER=$CMD_FILTER" \
    -t "$IMAGE" \
    "$WORKSPACE_ROOT"
}

_ensure_image()
{
  if ! "$CONTAINER_CMD" image inspect "$IMAGE" &>/dev/null
  then
    echo "Image $IMAGE not found — building first..."
    _build
  fi
}

_ensure_build_cache()
{
  local volume="${IMAGE}_target"
  if ! "$CONTAINER_CMD" volume inspect "$volume" &>/dev/null
  then
    echo "Seeding build cache from image (first run only)..."
    # Copy pre-compiled dep artifacts from image into the named volume.
    # The image target/ has deps from the cook stage; without seeding the volume
    # would start empty and force a full recompile from scratch on first use.
    # World-writable so the host uid (used by cmd_test via --user) can write build artifacts.
    "$CONTAINER_CMD" run --rm \
      -v "${volume}:/workspace/target_seed" \
      "$IMAGE" \
      bash -c "cp -a /workspace/target/. /workspace/target_seed/ && chmod -R a+rwX /workspace/target_seed/"
  fi
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_build()
{
  _build
  # Drop stale build caches so next use re-seeds from the new image.
  for volume in "${IMAGE}_target" "${IMAGE}_plugin_targets"
  do
    if "$CONTAINER_CMD" volume inspect "$volume" &>/dev/null
    then
      echo "Removing stale build cache volume: $volume..."
      "$CONTAINER_CMD" volume rm "$volume"
    fi
  done
}

cmd_test()
{
  local bin_args=()
  if [[ -n "$BIN_PLUGIN" ]]
  then
    local bin_name bin_container bin_host
    bin_name="${BIN_PLUGIN%%:*}"
    bin_container="${BIN_PLUGIN#*:}"
    bin_host="$(which "$bin_name" 2>/dev/null)" \
      || { echo "error: binary plugin '$bin_name' not found on PATH" >&2; exit 1; }
    bin_args=( -v "${IMAGE}_plugin_targets:$BIN_PLUGIN_VOLUME" -v "$bin_host:$bin_container:ro" )
  fi
  local mount_args=()
  if [[ -n "$PLUGIN_MOUNT" ]]
  then
    local plugin_mount
    plugin_mount="$(_resolve_mount "$PLUGIN_MOUNT" true rw)"
    mount_args=( -v "$plugin_mount" )
  fi
  _ensure_image
  # Run as the host user so mounted credential files (owned by host uid) are readable.
  # Rootless Podman remaps container uid 0 → host uid, so without --userns=keep-id
  # files owned by the host user appear as root inside the container and are unreadable
  # by a non-root container process.  keep-id preserves the host UID mapping so the
  # running uid matches the owner uid of the mounted credential files.
  # workspace and cargo dirs are world-writable (a+rwX in runbox.dockerfile) so the host
  # uid can write cargo lock files and build artifacts without owning those files.
  local userns_arg=()
  [[ "$CONTAINER_CMD" == "podman" ]] && userns_arg=( --userns=keep-id )
  "$CONTAINER_CMD" run --rm \
    "${userns_arg[@]}" \
    --user "$(id -u):$(id -g)" \
    "${bin_args[@]}" \
    "${mount_args[@]}" \
    "$IMAGE" \
    "/workspace/$TEST_SCRIPT"
}

cmd_test_offline()
{
  _ensure_image
  _ensure_build_cache
  # shellcheck disable=SC2086
  "$CONTAINER_CMD" run --rm \
    -v "${IMAGE}_target:/workspace/target" \
    "$IMAGE" \
    cargo nextest run $CMD_SCOPE --filter-expr "$CMD_FILTER"
}

cmd_list()
{
  _ensure_image
  local userns_arg=() vol_args=() cargo_env=""
  [[ "$CONTAINER_CMD" == "podman" ]] && userns_arg=( --userns=keep-id )
  # Same volume as cmd_test so .list artifacts persist between repeated .list calls.
  if [[ -n "$BIN_PLUGIN_VOLUME" ]]
  then
    vol_args=( -v "${IMAGE}_plugin_targets:$BIN_PLUGIN_VOLUME" )
    cargo_env="CARGO_TARGET_DIR=$BIN_PLUGIN_VOLUME "
  fi
  # shellcheck disable=SC2086
  "$CONTAINER_CMD" run --rm \
    "${userns_arg[@]}" \
    --user "$(id -u):$(id -g)" \
    "${vol_args[@]}" \
    "$IMAGE" \
    bash -c "${cargo_env}cargo nextest list $CMD_SCOPE --all-features"
}

cmd_shell()
{
  _ensure_image
  _ensure_build_cache
  local args=( --rm -it -v "${IMAGE}_target:/workspace/target" )
  if [[ -n "$BIN_PLUGIN" ]]
  then
    local bin_name bin_container bin_host
    bin_name="${BIN_PLUGIN%%:*}"
    bin_container="${BIN_PLUGIN#*:}"
    if bin_host="$(which "$bin_name" 2>/dev/null)"
    then
      args+=( -v "$bin_host:$bin_container:ro" )
    fi
  fi
  if [[ -n "$PLUGIN_MOUNT" ]]
  then
    local shell_mount
    shell_mount="$(_resolve_mount "$PLUGIN_MOUNT" false ro)"
    if [[ -n "$shell_mount" ]]
    then
      args+=( -v "$shell_mount" )
    fi
  fi
  "$CONTAINER_CMD" run "${args[@]}" "$IMAGE" bash
}

cmd_help()
{
  local plugin_hint=""
  if [[ -n "$PLUGIN_MOUNT" ]]
  then
    local plugin_host
    plugin_host="${PLUGIN_MOUNT%%:*}"
    plugin_hint=" ($plugin_host required)"
  fi
  echo "Usage: ./run/docker <command>"
  echo ""
  echo "Image Management:"
  echo "  .build          Build the $IMAGE container image"
  echo ""
  echo "Testing:"
  echo "  . / .test       Run all tests${plugin_hint}"
  echo "  .test.offline   Run offline tests only (no external data needed)"
  echo "  .list           List all test names without running"
  echo "  .shell          Interactive bash shell (mounts available)"
  echo ""
  echo "Help:"
  echo "  .help           Show this help"
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

case "$COMMAND" in
  .build)        cmd_build ;;
  .|.test)       cmd_test ;;
  .test.offline) cmd_test_offline ;;
  .list)         cmd_list ;;
  .shell)        cmd_shell ;;
  .help)         cmd_help ;;
  *)
    echo "error: unknown command '$COMMAND'" >&2
    echo "run './run/docker .help' for available commands" >&2
    exit 1
    ;;
esac
