# .cargo/ must be excluded so dev/.cargo/config.toml is never baked into container
# images.  The config redirects host-side cargo target dir to dev/-host-target/.
# Inside the container, cargo must continue using /workspace/target/ (seeded by the
# cook stage).  Baking the config in would silently invalidate all cook-stage cache
# on every run because cargo would switch target dirs and rebuild from scratch.
.cargo/

# Compiled artifacts — excluded to keep build context small.
# Docker will use target/ from the cook stage, not the host.
target/

# Hyphen-prefixed directories are temporary scratch space (investigations,
# experiments, notes). Never relevant to a container build.
-*/

# Git history is not needed inside the image.
.git/

