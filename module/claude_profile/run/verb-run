#!/usr/bin/env bash
# verb-run — universal verb dispatcher.
# Resolves the verb file and execs it; VERB_LAYER is passed via environment
# so the verb self-dispatches to the appropriate test.d/ layer.
#
# Usage: verb-run <verb-name> [args...]
#
# Resolution:
#   if verb/X is a file → exec it directly (it reads VERB_LAYER internally)
#   if neither          → exit 1 with a clear error
set -euo pipefail

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

if [[ $# -lt 1 ]]; then
  echo "usage: verb-run <verb-name> [args...]" >&2
  exit 1
fi

VERB_NAME="$1"
shift

VERB_PATH="$SCRIPT_DIR/../verb/$VERB_NAME"

if [[ -f "$VERB_PATH" ]]; then
  exec "$VERB_PATH" "$@"
else
  echo "error: verb '$VERB_NAME' not found at $VERB_PATH" >&2
  exit 1
fi
