#!/usr/bin/env bash
# l1 — run clp binary directly (cargo ecosystem).
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/../.."
if [[ "${1:-}" == "--dry-run" ]]; then echo "cargo run -p claude_profile --bin clp"; exit 0; fi
exec cargo run -p claude_profile --bin clp -- "$@"
