#!/usr/bin/env bash
# l1 — bare test execution (VERB_LAYER=l1); runs the workspace test suite inside the container.
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/../.."
if [[ "${1:-}" == "--dry-run" ]]; then echo "RUSTFLAGS=-D warnings cargo nextest run + doc test + clippy"; exit 0; fi
# Prevent cargo from trying to update the registry index inside the container.
# All deps are pre-cooked via cargo-chef during image build; registry is read-only.
export CARGO_NET_OFFLINE=true
# Fix(BUG-008): Disable nextest's interactive PTY progress bar inside the container.
# Root cause: The container runner spawns subprocesses via PTY, causing nextest to detect
#   isatty()=true and activate indicatif's cursor-movement progress display. The runner's
#   output normalization then discards this ANSI output, making all test results invisible
#   (exit 0, zero per-test lines visible in the collected output).
# Pitfall: NO_COLOR=1 makes indicatif return hidden()=true regardless of isatty(); nextest
#   falls back to plain newline-terminated output that survives the runner's normalization.
export NO_COLOR=1
export RUNBOX_CONTAINER=1
RUSTFLAGS="-D warnings" cargo nextest run --all-features
RUSTDOCFLAGS="-D warnings" cargo test --doc --all-features
exec cargo clippy --all-targets --all-features -- -D warnings
