#!/usr/bin/env bash
# do verify — full pre-push gate: container test suite + dependency analysis + audit
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
WORKSPACE_ROOT="$( cd "$SCRIPT_DIR/../.." && pwd )"
if [[ "${1:-}" == "--dry-run" ]]
then
  echo "./runbox/runbox .test && cargo +nightly udeps --all-targets --all-features && cargo +nightly audit"
  exit 0
fi
# Full test suite (nextest + doc tests + clippy) runs inside the container.
"$SCRIPT_DIR/../runbox/runbox" .test "$@"
# Dependency and audit checks run on the host (static analysis — no crate code executed).
cd "$WORKSPACE_ROOT"
cargo +nightly udeps --all-targets --all-features
if [ -f "Cargo.lock" ]
then
  cargo +nightly audit
else
  echo "ℹ Library crate — skipping audit (no Cargo.lock)"
fi
