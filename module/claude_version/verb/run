#!/usr/bin/env bash
# do run — execute the project entry point: clv binary (cargo ecosystem)
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/.."
if [[ "${1:-}" == "--dry-run" ]]; then echo "cargo run -p claude_version --bin clv"; exit 0; fi
exec cargo run -p claude_version --bin clv -- "$@"
