#!/usr/bin/env bash
# do build — compile project artifacts (cargo ecosystem)
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/.."
if [[ "${1:-}" == "--dry-run" ]]; then echo "cargo build -p claude_version"; exit 0; fi
exec cargo build -p claude_version
