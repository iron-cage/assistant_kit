#!/usr/bin/env bash
# do clean — remove generated artifacts and caches (cargo ecosystem)
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/.."
if [[ "${1:-}" == "--dry-run" ]]; then echo "cargo clean -p claude_storage_core"; exit 0; fi
exec cargo clean -p claude_storage_core
