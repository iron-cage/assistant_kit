#!/usr/bin/env bash
# test1 — run a targeted test by nextest filter expression inside the container.
# Usage: ./verb/test1 <nextest-filter-expression>
# Example: ./verb/test1 test_model_override_sets_budget
# Prefer this over verb/test when verifying a specific named test — no level-3 overhead.
set -euo pipefail
if [[ "${1:-}" == "--dry-run" ]]; then echo "./runbox/runbox .test1 '<filter>'"; exit 0; fi
FILTER="${1:-}"
if [[ -z "$FILTER" ]]; then
  echo "Usage: ./verb/test1 <nextest-filter-expression>" >&2
  echo "Example: ./verb/test1 test_model_override_sets_budget" >&2
  exit 1
fi
shift
exec "$(dirname "${BASH_SOURCE[0]}")/../runbox/runbox" .test1 "$FILTER" "$@"
