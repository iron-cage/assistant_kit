#!/usr/bin/env bash
# do verify — full checks: tests, lints, dependency analysis, audit (cargo ecosystem)
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/.."
if [[ "${1:-}" == "--dry-run" ]]; then
  echo "runbox/runbox .test"
  echo "cargo +nightly udeps --all-targets --all-features"
  echo "[ -f Cargo.lock ] && cargo +nightly audit"
  exit 0
fi
"$SCRIPT_DIR/../runbox/runbox" .test
cargo +nightly udeps --all-targets --all-features
if [ -f Cargo.lock ]; then
  cargo +nightly audit
else
  echo "ℹ Library crate - skipping audit (no Cargo.lock expected)"
fi
