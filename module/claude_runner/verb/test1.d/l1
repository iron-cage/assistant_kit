#!/usr/bin/env bash
# l1 — targeted nextest execution; runs a single nextest filter expression inside the container.
# Entered by cmd_test1 in runbox-run with VERB_FILTER set to the nextest filter expression.
# No level-3 overhead (no clippy, no doc tests) — nextest only.
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# Workspace root is 4 levels up from test1.d/ (test1.d → verb → claude_runner → module → workspace).
WORKSPACE_ROOT="$( cd "$SCRIPT_DIR/../../../.." && pwd )"
cd "$SCRIPT_DIR/../.."
if [[ -z "${VERB_FILTER:-}" ]]; then
  echo "error: VERB_FILTER is not set — invoke via './verb/test1 <filter>' or './runbox/runbox .test1 <filter>'" >&2
  exit 1
fi
# Prevent cargo from updating the registry index (deps are pre-cooked in the image).
export CARGO_NET_OFFLINE=true
# Disable nextest PTY progress bar (same reason as test.d/l1 — wrun_core PTY isatty).
export NO_COLOR=1
export RUSTFLAGS="-D warnings"
# Fix(test1-cargo-target-dir): Override host .cargo/config.toml target-dir redirect.
# Root cause: the host workspace is bind-mounted :ro into the container, bringing
# .cargo/config.toml (which has target-dir = "-host-target") into the container at
# /workspace/.cargo/config.toml.  Without this override, cargo nextest would try to
# write to /workspace/-host-target/ — part of the :ro bind-mount → EROFS on first write.
# Containers must use /workspace/target/ where the pre-seeded cook-stage volume is mounted.
# Pitfall: CARGO_TARGET_DIR env var overrides config.toml target-dir; set it explicitly here
# because test1 does not go through w3 which sets CARGO_TARGET_DIR in the full test path.
export CARGO_TARGET_DIR="$WORKSPACE_ROOT/target"
exec cargo nextest run --workspace --all-features --no-fail-fast -E "$VERB_FILTER"
