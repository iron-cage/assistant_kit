#!/usr/bin/env bash
# l1 — targeted nextest execution (VERB_LAYER=l1); runs a single NEXTEST_FILTER.
#
# Invoked by runbox-run cmd_test when NEXTEST_FILTER is set (via runbox/plugins.sh).
# Does NOT use w3; runs cargo nextest directly so the filter is applied without
# the level::3 full-suite overhead.  Uses /workspace/target (pre-seeded from the
# image build) for fast incremental compilation.
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/../.."
if [[ -z "${NEXTEST_FILTER:-}" ]]; then
  echo "ERROR: NEXTEST_FILTER is not set — invoke via ./verb/test1 <filter> on the host." >&2
  exit 1
fi
if [[ "${1:-}" == "--dry-run" ]]; then
  echo "RUSTFLAGS=\"-D warnings\" cargo nextest run --workspace --all-features \"$NEXTEST_FILTER\""
  exit 0
fi
# Prevent cargo from updating the registry index (deps are pre-cooked in the image).
export CARGO_NET_OFFLINE=true
# Disable nextest PTY progress bar (same reason as test.d/l1 — wrun_core PTY isatty).
export NO_COLOR=1
export RUNBOX_CONTAINER=1
export RUSTFLAGS="-D warnings"
exec cargo nextest run --workspace --all-features "$NEXTEST_FILTER"
