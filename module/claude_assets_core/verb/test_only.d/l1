#!/usr/bin/env bash
# l1 — targeted nextest execution (VERB_LAYER=l1); runs a single NEXTEST_FILTER.
#
# Invoked by runbox-run cmd_test when NEXTEST_FILTER is set (via runbox/plugins.sh).
# Does NOT use w3; runs cargo nextest directly so the filter is applied without
# the level::3 full-suite overhead.  Uses /workspace/target (pre-seeded from the
# image build) for fast incremental compilation.
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# Workspace root is 4 levels up from test_only.d/ (test_only.d → verb → <module> → module → workspace).
WORKSPACE_ROOT="$( cd "$SCRIPT_DIR/../../../.." && pwd )"
cd "$SCRIPT_DIR/../.."
if [[ -z "${NEXTEST_FILTER:-}" ]]; then
  echo "ERROR: NEXTEST_FILTER is not set — invoke via ./verb/test_only <filter> on the host." >&2
  exit 1
fi
if [[ "${1:-}" == "--dry-run" ]]; then
  echo "RUSTFLAGS=\"-D warnings\" cargo nextest run --all-features \"$NEXTEST_FILTER\""
  exit 0
fi
export CARGO_NET_OFFLINE=true
export NO_COLOR=1
export RUNBOX_CONTAINER=1
export RUSTFLAGS="-D warnings"
# Fix(test_only-cargo-target-dir): Override host .cargo/config.toml target-dir redirect.
# Root cause: the host workspace is bind-mounted :ro into the container, bringing
# .cargo/config.toml (which has target-dir = "-host-target") into the container at
# /workspace/.cargo/config.toml.  Without this override, cargo nextest would try to
# write to /workspace/-host-target/ — part of the :ro bind-mount → EROFS on first write.
# Pitfall: CARGO_TARGET_DIR env var overrides config.toml target-dir; set it explicitly here
# because test_only skips the w3 bin_plugin that sets CARGO_TARGET_DIR in the full test path.
export CARGO_TARGET_DIR="$WORKSPACE_ROOT/target"
exec cargo nextest run --all-features "$NEXTEST_FILTER"
