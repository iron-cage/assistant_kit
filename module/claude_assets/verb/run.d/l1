#!/usr/bin/env bash
# l1 — run cla binary directly (cargo ecosystem).
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/../.."
if [[ "${1:-}" == "--dry-run" ]]; then echo "cargo run -p claude_assets --bin cla"; exit 0; fi
exec cargo run -p claude_assets --bin cla -- "$@"
