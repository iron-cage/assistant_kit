#!/usr/bin/env bash
# claude_storage container test runner
# Usage: ./run/docker <command>
set -euo pipefail

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
WORKSPACE_ROOT="$( cd "$SCRIPT_DIR/../../.." && pwd )"
DOCKERFILE="$( cd "$SCRIPT_DIR/.." && pwd )/Dockerfile"
IMAGE=claude_storage_test

# ── Container runtime ─────────────────────────────────────────────────────────

if command -v podman &>/dev/null; then
  CONTAINER_CMD=podman
elif command -v docker &>/dev/null; then
  CONTAINER_CMD=docker
else
  echo "error: neither podman nor docker found" >&2
  exit 1
fi

# ── Helpers ───────────────────────────────────────────────────────────────────

_build()
{
  echo "Building $IMAGE using $CONTAINER_CMD..."
  "$CONTAINER_CMD" build -f "$DOCKERFILE" -t "$IMAGE" "$WORKSPACE_ROOT"
}

_ensure_image()
{
  if ! "$CONTAINER_CMD" image inspect "$IMAGE" &>/dev/null; then
    echo "Image $IMAGE not found — building first..."
    _build
  fi
}

_ensure_build_cache()
{
  local volume="${IMAGE}_target"
  if ! "$CONTAINER_CMD" volume inspect "$volume" &>/dev/null; then
    echo "Seeding build cache from image (first run only)..."
    # Copy pre-compiled dep artifacts from image into the named volume.
    # The image target/ has deps from the cook stage; without seeding the volume
    # would start empty and force a full recompile from scratch on first use.
    "$CONTAINER_CMD" run --rm \
      -v "${volume}:/workspace/target_seed" \
      "$IMAGE" \
      bash -c "cp -a /workspace/target/. /workspace/target_seed/"
  fi
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_build()
{
  _build
  # Drop stale build cache so next .test re-seeds from the new image.
  local volume="${IMAGE}_target"
  if "$CONTAINER_CMD" volume inspect "$volume" &>/dev/null; then
    echo "Removing stale build cache volume..."
    "$CONTAINER_CMD" volume rm "$volume"
  fi
}

cmd_test()
{
  local claude_dir="$HOME/.claude"
  if [[ ! -d "$claude_dir" ]]; then
    echo "error: ~/.claude/ not found at $claude_dir" >&2
    echo "behavior tests require real Claude Code storage" >&2
    exit 1
  fi
  local w3_bin
  w3_bin="$(which w3 2>/dev/null)" \
    || { echo "error: w3 (willbe3) not found on PATH — install it on the host first" >&2; exit 1; }
  _ensure_image
  _ensure_build_cache
  "$CONTAINER_CMD" run --rm \
    -v "${IMAGE}_target:/workspace/target" \
    -v "$w3_bin":/usr/local/bin/w3:ro \
    -v "$claude_dir":/workspace/.claude:ro \
    "$IMAGE" \
    bash -c "cd /workspace/module/claude_storage && w3 .test level::3"
}

cmd_test_offline()
{
  _ensure_image
  _ensure_build_cache
  "$CONTAINER_CMD" run --rm \
    -v "${IMAGE}_target:/workspace/target" \
    "$IMAGE" \
    cargo nextest run -p claude_storage --filter-expr '!binary(behavior)'
}

cmd_help()
{
  echo "Usage: ./run/docker <command>"
  echo ""
  echo "Image Management:"
  echo "  .build          Build the $IMAGE container image"
  echo ""
  echo "Testing:"
  echo "  . / .test       Run all tests (real ~/.claude/ required)"
  echo "  .test.offline   Run offline tests only (no ~/.claude/ needed)"
  echo ""
  echo "Help:"
  echo "  .help           Show this help"
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

COMMAND="${1:-.test}"

case "$COMMAND" in
  .build)        cmd_build ;;
  .|.test)       cmd_test ;;
  .test.offline) cmd_test_offline ;;
  .help)         cmd_help ;;
  *)
    echo "error: unknown command '$COMMAND'" >&2
    echo "run './run/docker .help' for available commands" >&2
    exit 1
    ;;
esac
