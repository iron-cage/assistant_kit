#!/usr/bin/env bash
# l1 — run clg binary directly (cargo ecosystem).
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/../.."
if [[ "${1:-}" == "--dry-run" ]]; then echo "cargo run -p claude_storage --bin clg"; exit 0; fi
exec cargo run -p claude_storage --bin clg -- "$@"
