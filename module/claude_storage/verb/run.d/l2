#!/usr/bin/env bash
# l2 — host orchestration; delegates to runbox (Docker-orchestrated execution).
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/../.."
if [[ "${1:-}" == "--dry-run" ]]; then echo "./run/runbox .run"; exit 0; fi
exec ./run/runbox .run
