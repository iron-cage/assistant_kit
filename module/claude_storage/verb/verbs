#!/usr/bin/env bash
# do verbs — list available verbs for this project (protocol meta-verb)
set -euo pipefail
printf '%-8s %-11s %s\n' build   available "cargo build -p claude_storage"
printf '%-8s %-11s %s\n' test    available "w3 .test level::3"
printf '%-8s %-11s %s\n' clean   available "cargo clean -p claude_storage"
printf '%-8s %-11s %s\n' run     available "cargo run -p claude_storage --bin clg"
printf '%-8s %-11s %s\n' lint    available "cargo clippy -p claude_storage --all-features -- -D warnings"
printf '%-8s %-11s %s\n' verify   available   "w3 .test level::4"
printf '%-8s %-11s %s\n' verbs   built-in  "-"
printf '%-8s %-11s %s\n' detect  built-in  "-"
