#!/usr/bin/env bash
# do verify — run offline tests (no external data required)
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/.."
if [[ "${1:-}" == "--dry-run" ]]; then echo "./runbox/runbox .test.offline"; exit 0; fi
exec ./runbox/runbox .test.offline
