#!/usr/bin/env bash
# l1 — bare test execution (VERB_LAYER=l1); runs the workspace test suite inside the container.
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/../.."
if [[ "${1:-}" == "--dry-run" ]]; then echo "RUSTFLAGS=-D warnings cargo nextest run + doc test + clippy"; exit 0; fi
# Prevent cargo from trying to update the registry index inside the container.
# All deps are pre-cooked via cargo-chef during image build; registry is read-only.
export CARGO_NET_OFFLINE=true
# Override target-dir from .cargo/config.toml which redirects to -host-target for
# host builds.  Inside the container the workspace is mounted read-only, so -host-target
# is not writable.  Force cargo to use /workspace/target (the cook-stage volume).
export CARGO_TARGET_DIR=/workspace/target
# Fix(BUG-008): Disable nextest's interactive PTY progress bar.
# Root cause: when the test runner captures subprocess output via PTY, nextest detects
# isatty()=true and activates indicatif's cursor-movement progress display. The output
# capture layer discards these ANSI control sequences, making all test results invisible
# (exit 0, zero per-test lines visible).
# With NO_COLOR=1, nextest uses hidden()=true regardless of isatty(), and falls back
# to plain \n-terminated output that survives output capture intact.
# Pitfall: environment inheritance ensures this env var propagates to nested runners
# automatically — the fix applies regardless of test runner binary version.
export NO_COLOR=1
# Scoped to the claude_runner package: this workspace checkout bundles every
# assistant_kit module in one Cargo workspace, and an unscoped run compiles
# unrelated sibling crates (e.g. claude_storage) that this module does not
# depend on. This script is this workspace's own copy — module-specific.
RUSTFLAGS="-D warnings" cargo nextest run -p claude_runner --all-features
RUSTDOCFLAGS="-D warnings" cargo test --doc -p claude_runner --all-features
exec cargo clippy -p claude_runner --all-targets --all-features -- -D warnings
