#!/usr/bin/env bash
# l1_filter — targeted single-filter test execution inside the container.
# Entered by runbox-run cmd_test1() with NEXTEST_FILTER set.
# Runs only nextest with the given filter — no doc tests, no clippy.
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/../.."
FILTER="${NEXTEST_FILTER:-}"
if [[ -z "$FILTER" ]]; then
  echo "error: NEXTEST_FILTER env var not set" >&2
  echo "Use ./verb/test1 <filter> instead of calling this script directly" >&2
  exit 1
fi
# Prevent cargo from trying to update the registry index inside the container.
# All deps are pre-cooked via cargo-chef during image build; registry is read-only.
export CARGO_NET_OFFLINE=true
# Override target-dir: workspace is :ro in the container; cook-stage volume is writable.
export CARGO_TARGET_DIR=/workspace/target
# Fix(BUG-008): Disable nextest's interactive PTY progress bar.
# See verb/test.d/l1 for full rationale.
export NO_COLOR=1
export RUSTFLAGS="-D warnings"
# Scoped to the claude_runner package: this workspace checkout bundles every
# assistant_kit module in one Cargo workspace, and an unscoped run compiles
# unrelated sibling crates (e.g. claude_storage) that this module does not
# depend on. This script is this workspace's own copy — module-specific.
exec cargo nextest run -p claude_runner --all-features --no-fail-fast -E "$FILTER"
